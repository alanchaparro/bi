# Keep image context minimal and avoid shipping local sensitive files
.git
.gitignore
.env
.env.*
!.env.example

# Local data dumps
*.csv
*.xlsx
analytics_meta.json

# Temp files under repo (Windows: puede bloquear build context con Permission denied)
**/tmp*

# Cache/artifacts
.cache
__pycache__
*.pyc
*.pyo
*.pyd
*.log

# CI/dev files not needed at runtime
.github
frontend/node_modules
frontend/dist
